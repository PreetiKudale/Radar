<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CrossBrowserAutomationSuite" parallel="false">

    <!-- Run tests in Chrome -->
    <test name="Botmatic Websites - Chrome">
        <parameter name="os" value="Windows"/>
        <parameter name="Browser" value="chrome"/>
        <classes>
            <class name="allWebsites.ofelostrade"/>
            <class name="allWebsites.eliteVibes"/>
            <class name="allWebsites.sunriseFoundation"/>
            <class name="allWebsites.botmaticSolutionCom"/>
            <class name="allWebsites.botmaticSolutions"/>
            <class name="allWebsites.caJpd"/>
            <class name="allWebsites.claimMyShares"/>
            <class name="allWebsites.eliteTravelDesk"/>
            <class name="allWebsites.myVyayCom"/>
        </classes>
    </test>

    <!-- Run tests in Firefox -->
    <test name="Botmatic Websites - Firefox">
        <parameter name="os" value="Windows"/>
        <parameter name="Browser" value="firefox"/>
        <classes>
            <class name="allWebsites.ofelostrade"/>
            <class name="allWebsites.eliteVibes"/>
            <class name="allWebsites.sunriseFoundation"/>
            <class name="allWebsites.botmaticSolutionCom"/>
            <class name="allWebsites.botmaticSolutions"/>
            <class name="allWebsites.caJpd"/>
            <class name="allWebsites.claimMyShares"/>
            <class name="allWebsites.eliteTravelDesk"/>
            <class name="allWebsites.myVyayCom"/>
        </classes>
    </test>

    <!-- Run tests in Edge -->
    <test name="Botmatic Websites - Edge">
        <parameter name="os" value="Windows"/>
        <parameter name="Browser" value="edge"/>
        <classes>
            <class name="allWebsites.ofelostrade"/>
            <class name="allWebsites.eliteVibes"/>
            <class name="allWebsites.sunriseFoundation"/>
            <class name="allWebsites.botmaticSolutionCom"/>
            <class name="allWebsites.botmaticSolutions"/>
            <class name="allWebsites.caJpd"/>
            <class name="allWebsites.claimMyShares"/>
            <class name="allWebsites.eliteTravelDesk"/>
            <class name="allWebsites.myVyayCom"/>
        </classes>
    </test>

</suite>
