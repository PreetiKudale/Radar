<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <!-- Define properties -->
    <Properties>
        <Property name="basePath">./logs</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>

        <!-- Rolling File Appender -->
        <RollingFile name="File" fileName="${basePath}/RadarAutomation.log"
                     filePattern="${basePath}/RadarAutomation-%d{yyyy-MM-dd}.log">
            <PatternLayout Pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
            <SizeBasedTriggeringPolicy size="10MB"/>
        </RollingFile>

    </Appenders>

    <Loggers>
        <!-- Root logger references the rolling appender -->
        <Root level="Info">
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>

</Configuration>
